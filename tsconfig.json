{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "NodeNext",
    "moduleResolution": "NodeNext",
    "lib":              ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict":           false,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "types":            ["node"]
  },
  "include": ["src/**/*", "tests/**/*", "prisma/**/*"],
  "exclude": ["node_modules", "dist"]
}